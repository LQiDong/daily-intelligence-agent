# ========== LLM API ==========
# Provider: "openai" (default) or "anthropic"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic (only needed when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ========== Email (SMTP) ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@example.com
SMTP_RETRY_COUNT=3
SMTP_RETRY_DELAY=5
SMTP_USE_SSL=false

# ========== Collector API Keys ==========
NEWSAPI_API_KEY=
ALPHA_VANTAGE_API_KEY=

# ========== Collector Switches (true / false) ==========
COLLECTOR_RSS_ENABLED=true
COLLECTOR_NEWSAPI_ENABLED=true
COLLECTOR_GDELT_ENABLED=true
COLLECTOR_ALPHA_VANTAGE_ENABLED=true
COLLECTOR_ARXIV_ENABLED=true

# ========== RSS Feeds (comma-separated) ==========
RSS_FEEDS=https://hnrss.org/frontpage,https://feeds.feedburner.com/TechCrunch,https://www.theverge.com/rss/index.xml,https://feeds.arstechnica.com/arstechnica/index

# ========== Application ==========
LOG_LEVEL=INFO
DATA_RETENTION_DAYS=7
FETCH_DAYS=3
SCHEDULED_TIME=08:00
HTTP_TIMEOUT=30
